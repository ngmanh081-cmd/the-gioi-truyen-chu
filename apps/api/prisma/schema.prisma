generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Novel {
  id          String     @id @default(cuid())
  title       String
  description String     @db.NVarChar(Max)
  coverImage  String?
  author      String
  categories  Category[] @relation("NovelCategories")
  chapters    Chapter[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([createdAt])
  @@index([title])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  novels    Novel[]  @relation("NovelCategories")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chapter {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.NVarChar(Max)
  order     Int
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([novelId, order])
  @@index([novelId, order])
}
